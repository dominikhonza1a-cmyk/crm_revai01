# ── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=Europe/Prague
DEFAULT_CURRENCY=CZK

# ── Supabase (DB + Auth) ────────────────────────────────────────────────
# Založ projekt na https://supabase.com (region EU / Frankfurt kvůli GDPR).
# Project Settings → API (nový formát klíčů: Publishable / Secret):
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...      # klient (dřív "anon public")
SUPABASE_SECRET_KEY=sb_secret_...                # jen server-side; NIKDY do klienta/gitu

# Project Settings → Database → Connection string:
#  - DATABASE_URL = Transaction pooler (port 6543) → pro web app (serverless-safe, prepare:false)
#  - DIRECT_URL   = Direct/Session (port 5432)     → pro migrace a worker (LISTEN/NOTIFY, advisory locks)
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgres://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Auth ────────────────────────────────────────────────────────────────
AUTH_PROVIDER=supabase          # supabase | better_auth (přepnutelné přes AuthProvider port)
# MFA: TOTP (Google Authenticator / 1Password) — zapnuto v Supabase Auth → Providers → MFA.
# Google OAuth přidáme později (Supabase Auth → Providers → Google).

# ── Tenancy ─────────────────────────────────────────────────────────────
TENANCY_MODE=single             # single = self-hosted (jeden workspace), multi = SaaS
SEED_WORKSPACE_NAME=revai
SEED_OWNER_EMAILS=owner1@example.com,owner2@example.com

# ── Secrets store (reference, NE hodnoty) ───────────────────────────────
SECRETS_BACKEND=env             # env | vault | 1password

# ── Email (odchozí připomínky + digest; sync později) ───────────────────
EMAIL_PROVIDER=console          # console | smtp | gmail | outlook
# SMTP: Gmail/Workspace → smtps://uzivatel%40domena.cz:APP_HESLO@smtp.gmail.com:465
SMTP_URL=
SMTP_FROM=                      # např. "revai CRM <info@automatizace-ai.cz>"

# ── Nasazení (Netlify) ──────────────────────────────────────────────────
# Náhodný token chránící /api/jobs (spouští ho Netlify cron funkce místo workeru):
CRON_SECRET=

# ── Chat notifikace (odchozí webhook) ───────────────────────────────────
CHAT_PROVIDER=console           # console | webhook
CHAT_WEBHOOK_URL=

# ── Document storage ────────────────────────────────────────────────────
STORAGE_PROVIDER=link           # link (reference) | supabase | s3
STORAGE_BUCKET=documents        # jen pro nativní upload (Supabase Storage), fáze 2

# ── Scheduler / worker ──────────────────────────────────────────────────
DIGEST_DEFAULT_HOUR=7
