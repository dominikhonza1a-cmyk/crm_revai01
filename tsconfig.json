{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/domain/*": [
        "src/domain/*"
      ],
      "@/modules/*": [
        "src/modules/*"
      ],
      "@/adapters/*": [
        "src/adapters/*"
      ],
      "@/shared": [
        "src/shared/index.ts"
      ],
      "@/shared/*": [
        "src/shared/*"
      ],
      "@/workflows/*": [
        "src/workflows/*"
      ],
      "@/api/*": [
        "src/api/*"
      ],
      "@/ui/*": [
        "src/ui/*"
      ],
      "@/config/*": [
        "config/*"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "config",
    "db",
    "examples",
    "scripts",
    "src",
    "tests",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
