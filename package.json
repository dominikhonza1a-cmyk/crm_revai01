{
  "name": "revai-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Interní CRM pro AI automatizační agenturu",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "worker": "tsx --env-file=.env src/worker.ts",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env scripts/migrate.ts",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "db:reset": "tsx --env-file=.env scripts/dev-reset.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "next": "^15.0.0",
    "nodemailer": "^9.0.3",
    "pg-boss": "^10.1.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "comment": "Verze jsou orientační. Scaffold neinstaluje závislosti — slouží jako kontrakt pro implementaci."
}
